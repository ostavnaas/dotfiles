#!/usr/bin/env bash
set -euo pipefail

VERSION="${1:-v0.12.2}"
REPO_DIR="$HOME/github/neovim"

packages=(
    git
    ninja-build
    gettext
    cmake
    unzip
    curl
    build-essential
    pkg-config
  )

missing_packages=()

for package in "${packages[@]}"; do
  if ! dpkg-query -W -f='${Status}' "$package" 2>/dev/null | grep -q "install ok installed"; then
    missing_packages+=("$package")
  fi
done

if ((${#missing_packages[@]} > 0)); then
  sudo apt-get update
  sudo apt-get install -y "${missing_packages[@]}"
fi

mkdir -p "$HOME/github"

if [ ! -d "$REPO_DIR/.git" ]; then
  git clone https://github.com/neovim/neovim.git "$REPO_DIR"
fi

git -C "$REPO_DIR" fetch --tags --prune
git -C "$REPO_DIR" checkout --detach "tags/$VERSION"

make -C "$REPO_DIR" distclean
make -C "$REPO_DIR" CMAKE_BUILD_TYPE=RelWithDebInfo -j"$(nproc)"

(
  cd "$REPO_DIR/build"
  cpack -G DEB
  sudo apt-get install -y ./nvim-linux-x86_64.deb
)

