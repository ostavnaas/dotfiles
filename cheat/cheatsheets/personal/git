# Revert merge commit
git reset --merge HEAD~1

# Files changes between HEAD~3 and HEAD
git diff --name-only HEAD~3..HEAD folder

# Show files
git show --name-only

# git diff in vim
git difftool --tool=vimdiff --no-prompt origin/master

# lists branches merged into master
git branch --merged master

# Clean up branches and tags that have been deleted in remote
git fetch --prune --prune-tags origin



# list files and sort by size
git ls-tree -r -t -l --full-name HEAD | sort -n -k 4

# https://stackoverflow.com/questions/25356810/how-to-squash-all-commits-on-branch
# How to squash all commits on branch
git reset $(git merge-base master $(git rev-parse --abbrev-ref HEAD))


# Show the short hash of the latest commit on origin/master
git rev-parse --short=8 origin/master
 -> e9630ccf
